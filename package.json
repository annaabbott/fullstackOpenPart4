{
  "name": "fullstackopenpart3",
  "version": "1.0.0",
  "type": "module",
  "description": "backend to phonebook app",
  "main": "index.js",
  "scripts": {
    "start": "cross-env NODE_ENV=production node index.js",
    "dev": "cross-env NODE_ENV=development node --watch index.js",
    "test": "cross-env NODE_ENV=test node --test",
    "test:watch": "cross-env NODE_ENV=test node --test --watch",
    "build:ui": "rimraf dist && cd ../fullstackOpenPart2 && npm run build && shx cp -r dist ../fullstackOpenPart3",
    "deploy:full": "npm run build:ui && git add . && git commit -m uibuild && git push",
    "lint": "eslint ."
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/annaabbott/fullstackOpenPart3.git"
  },
  "author": "Anna Abbott",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/annaabbott/fullstackOpenPart3/issues"
  },
  "homepage": "https://github.com/annaabbott/fullstackOpenPart3#readme",
  "dependencies": {
    "body-parser": "^2.2.2",
    "cors": "^2.8.6",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "mongoose": "^9.4.1",
    "morgan": "^1.10.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "rimraf": "^6.1.3",
    "shx": "^0.4.0"
  }
}
